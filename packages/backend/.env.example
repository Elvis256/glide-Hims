# ===========================================
# Glide-HIMS Backend Configuration
# ===========================================

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=CHANGE_ME_db_username
DB_PASSWORD=CHANGE_ME_use_strong_random_password
DB_NAME=CHANGE_ME_db_name

# Redis Configuration (for rate limiting/caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# JWT Configuration
# ⚠️  REQUIRED: Generate strong random secrets before first run
# Example: openssl rand -base64 64
JWT_SECRET=your-secret-here-min-64-chars-generate-with-openssl-rand-base64-64
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-here-min-64-chars-generate-with-openssl-rand-base64-64
JWT_REFRESH_EXPIRES_IN=7d

# Application Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Deployment mode: 'standalone' (single hospital) or 'multi-tenant' (SaaS)
DEPLOYMENT_MODE=standalone

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# File Storage (MinIO/S3-compatible)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key
MINIO_USE_SSL=false
MINIO_BUCKET=glide-hims

# RabbitMQ Configuration (for async jobs)
RABBITMQ_URL=amqp://localhost:5672

# Security Settings
BCRYPT_ROUNDS=12
MFA_ISSUER=Glide-HIMS

# Rate Limiting (requests per TTL window per IP)
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# ===========================================
# Production Checklist
# ===========================================
# Before deploying to production, ensure:
# 1. NODE_ENV=production
# 2. JWT_SECRET and JWT_REFRESH_SECRET are strong random strings (64+ chars)
# 3. DB_PASSWORD is a strong, unique password
# 4. CORS_ORIGINS lists only your actual frontend domains
# 5. MINIO_ACCESS_KEY and MINIO_SECRET_KEY are changed from defaults
# 6. MINIO_USE_SSL=true
# 7. LOG_LEVEL=warn
# 8. SSL certificates are placed in ssl/ directory
