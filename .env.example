# =============================================================================
# Glide HIMS - Environment Configuration
# Copy this file to .env and update with your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
APP_NAME=Glide HIMS
HOSPITAL_NAME=Your Hospital Name
NODE_ENV=production

# Deployment mode: multi-tenant | on-premise | dedicated
DEPLOYMENT_MODE=on-premise

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=glide_hims
DB_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
DB_DATABASE=glide_hims

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING
JWT_EXPIRATION=24h

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
BACKEND_PORT=3000
FRONTEND_PORT=80
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# License Configuration (On-Premise Only)
# -----------------------------------------------------------------------------
# License key provided by IT Solutions Uganda
LICENSE_KEY=

# License server URL for validation
LICENSE_SERVER_URL=https://hmisdemo.itsolutionsuganda.com/api/license

# -----------------------------------------------------------------------------
# Phone Home / Telemetry (On-Premise Only)
# -----------------------------------------------------------------------------
# Enable phone-home for license validation and updates
PHONE_HOME_ENABLED=true
PHONE_HOME_URL=https://hmisdemo.itsolutionsuganda.com/api/phone-home
PHONE_HOME_INTERVAL=86400

# -----------------------------------------------------------------------------
# Support Contact
# -----------------------------------------------------------------------------
SUPPORT_EMAIL=support@itsolutionsuganda.com
SUPPORT_PHONE=+256700000000

# -----------------------------------------------------------------------------
# Optional: SSL/TLS (Production)
# -----------------------------------------------------------------------------
# SSL_CERT_PATH=/etc/nginx/ssl/certificate.crt
# SSL_KEY_PATH=/etc/nginx/ssl/private.key

# -----------------------------------------------------------------------------
# Optional: Backup Configuration
# -----------------------------------------------------------------------------
# BACKUP_ENABLED=true
# BACKUP_CRON=0 2 * * *
# BACKUP_RETENTION_DAYS=30
# BACKUP_S3_BUCKET=
# BACKUP_S3_ACCESS_KEY=
# BACKUP_S3_SECRET_KEY=
