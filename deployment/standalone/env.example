# ─── Glide-HIMS standalone configuration ───
# Copy to `.env` and fill in real values. Never commit .env to git.

# --- Database ---
DB_DATABASE=glide_hims
DB_USERNAME=glide_hims
# Generate: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_BEFORE_INSTALL

# --- Authentication secrets ---
# Generate each: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_BEFORE_INSTALL
JWT_REFRESH_SECRET=CHANGE_ME_BEFORE_INSTALL

# --- Versioning ---
HIMS_VERSION=latest

# --- Networking ---
HTTP_PORT=80
HTTPS_PORT=443

# --- Backups ---
BACKUP_RETENTION_DAYS=90
# Optional GPG passphrase for at-rest backup encryption (recommended)
BACKUP_ENCRYPTION_KEY=

# --- Phone-home / licensing (for hybrid sites; leave blank for fully air-gapped) ---
LICENSE_KEY=
CENTRAL_SERVER_URL=https://hmisdemo.itsolutionsuganda.com
DEPLOYMENT_ID=
